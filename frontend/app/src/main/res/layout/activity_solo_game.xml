<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/background_gradient"
    tools:context=".presentation.ui.soloGame.SoloGameActivity">
    <include layout="@layout/include_connection_banner"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="26dp"
        android:paddingBottom="12dp"
        android:layout_marginBottom="20dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_question_number"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1/10"
                android:textColor="?attr/colorTertiary"
                android:textSize="20sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/question"
                android:textColor="?attr/colorTertiaryFixed"
                android:textSize="16sp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <TextView
                android:id="@+id/tv_timer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="?attr/colorPrimary"
                android:textSize="24sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/time"
                android:textColor="?attr/colorTertiaryFixed"
                android:textSize="16sp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/tv_score"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="5sp"
                android:text="0"
                android:textColor="?attr/colorTertiary"
                android:textSize="22sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/score"
                android:textColor="?attr/colorTertiaryFixed"
                android:textSize="16sp"/>
        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/progress_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="24dp"
        android:visibility="gone"/>

    <TextView
        android:id="@+id/tv_question_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="?attr/colorTertiary"
        android:gravity="center"
        android:layout_marginBottom="16dp"
        android:layout_marginHorizontal="16dp"
        android:text="@string/capital_question"/>

    <FrameLayout
        android:id="@+id/image_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:layout_marginHorizontal="72dp"
        android:background="@drawable/border"
        android:visibility="visible">

        <ImageView
            android:id="@+id/iv_question_image"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:scaleType="fitCenter"
            android:padding="2dp"/>
    </FrameLayout>

    <LinearLayout
        android:id="@+id/audio_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginBottom="16dp"
        android:visibility="visible">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_audio"
            android:layout_width="48dp"
            android:layout_height="48dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="?attr/colorPrimary"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/btn_play_audio"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_play_audio"
                android:clickable="true"
                android:focusable="true"
                app:tint="?attr/colorOnPrimary" />

        </com.google.android.material.card.MaterialCardView>
        <LinearLayout
            android:id="@+id/layout_wave"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:visibility="visible"
            android:layout_marginTop="4dp">

            <View
                android:id="@+id/wave1"
                android:layout_width="4dp"
                android:layout_height="12dp"
                android:background="?attr/colorAccent"
                android:layout_marginEnd="3dp"
                app:cornerRadius="2dp"/>

            <View
                android:id="@+id/wave2"
                android:layout_width="4dp"
                android:layout_height="20dp"
                android:background="?attr/colorAccent"
                android:layout_marginEnd="3dp"
                app:cornerRadius="2dp"/>

            <View
                android:id="@+id/wave3"
                android:layout_width="4dp"
                android:layout_height="16dp"
                android:background="?attr/colorAccent"
                android:layout_marginEnd="3dp"
                app:cornerRadius="2dp"/>

            <View
                android:id="@+id/wave4"
                android:layout_width="4dp"
                android:layout_height="24dp"
                android:background="?attr/colorAccent"
                app:cornerRadius="2dp"/>

        </LinearLayout>
        <TextView
            android:id="@+id/tv_audio_hint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/play_audio"
            android:textColor="?attr/colorTertiaryFixed"
            android:textSize="12sp"
            android:layout_marginTop="8dp"
            android:gravity="center_horizontal"/>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/options_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="16dp"
        android:orientation="vertical"
        android:gravity="center">

        <Button
            android:id="@+id/btn_option1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:backgroundTint="@null"
            style="@style/QuizOptionButton"/>

        <Button
            android:id="@+id/btn_option2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:backgroundTint="@null"
            style="@style/QuizOptionButton"/>

        <Button
            android:id="@+id/btn_option3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:backgroundTint="@null"
            style="@style/QuizOptionButton"/>

        <Button
            android:id="@+id/btn_option4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:backgroundTint="@null"
            style="@style/QuizOptionButton"/>

    </LinearLayout>
    <Button
        android:id="@+id/btn_end_game"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginHorizontal="16dp"
        android:text="@string/end_game"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="?attr/colorPrimary"
        android:textColor="?attr/colorOutline"
        app:cornerRadius="16dp"
        android:layout_marginBottom="40dp"/>

</LinearLayout>