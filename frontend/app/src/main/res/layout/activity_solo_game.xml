<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/background_gradient"
    tools:context=".presentation.ui.Game.SoloGameActivity">
    <include layout="@layout/include_connection_banner"/>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:layout_marginBottom="16dp"
        android:layout_marginTop="20dp">

        <TextView
            android:id="@+id/tv_question_number"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/question"
            android:textSize="16sp"
            android:textColor="?attr/colorTertiary"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tv_score"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textSize="16sp"
            android:textColor="?attr/colorPrimary"
            android:textStyle="bold"
            android:layout_marginEnd="16dp"
            android:padding="8dp"/>

        <TextView
            android:id="@+id/tv_timer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="01:00"
            android:textSize="20sp"
            android:textColor="?attr/colorTertiary"
            android:textStyle="bold"
            android:background="@drawable/timer_bg"
            android:padding="8dp" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/progress_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="24dp"
        android:visibility="gone"/>

    <TextView
        android:id="@+id/tv_question_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="?attr/colorTertiary"
        android:gravity="center"
        android:layout_marginBottom="16dp"
        android:text="@string/capital_question"/>

    <FrameLayout
        android:id="@+id/image_container"
        android:layout_width="240dp"
        android:layout_height="150dp"
        android:layout_gravity="center"
        android:layout_marginBottom="24dp"
        android:background="?attr/colorSurfaceInverse"
        android:visibility="gone">

        <ImageView
            android:id="@+id/iv_question_image"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter"
            android:padding="4dp"/>
    </FrameLayout>

    <Button
        android:id="@+id/btn_play_audio"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="@string/play_audio"
        android:layout_marginBottom="24dp"
        android:visibility="gone"
        style="@style/QuizOptionButton"/>

    <LinearLayout
        android:id="@+id/options_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="16dp"
        android:orientation="vertical"
        android:gravity="center">

        <Button
            android:id="@+id/btn_option1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:backgroundTint="@null"
            style="@style/QuizOptionButton"/>

        <Button
            android:id="@+id/btn_option2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:backgroundTint="@null"
            style="@style/QuizOptionButton"/>

        <Button
            android:id="@+id/btn_option3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:backgroundTint="@null"
            style="@style/QuizOptionButton"/>

        <Button
            android:id="@+id/btn_option4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:backgroundTint="@null"
            style="@style/QuizOptionButton"/>

    </LinearLayout>
    <Button
        android:id="@+id/btn_end_game"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginHorizontal="16dp"
        android:text="@string/end_game"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="?attr/colorPrimary"
        android:textColor="?attr/colorOutline"
        app:cornerRadius="16dp"
        android:layout_marginBottom="40dp"/>

</LinearLayout>