<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardPlayer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="6dp"
    app:cardCornerRadius="12dp"
    app:strokeWidth="1dp"
    app:strokeColor="?attr/colorTertiaryFixed"
    app:cardElevation="1dp"
    app:cardBackgroundColor="@android:color/transparent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/card_background_game"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <FrameLayout
            android:layout_width="50dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical">

            <TextView
                android:id="@+id/tvRank"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1"
                android:textColor="?attr/colorTertiary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_gravity="center"/>

            <TextView
                android:id="@+id/tvMedal"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:text="🥇"
                android:textSize="20sp"
                android:gravity="center"
                android:visibility="gone"
                android:layout_gravity="center"/>
        </FrameLayout>


        <TextView
            android:id="@+id/tvPlayerName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="PlayerName"
            android:textColor="?attr/colorTertiary"
            android:textSize="15sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/tvYouBadge"
            android:layout_width="wrap_content"
            android:layout_height="20dp"
            android:paddingHorizontal="6dp"
            android:text="@string/your_stats"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:background="@drawable/bg_you_badge"
            android:gravity="center"
            android:visibility="visible"
            app:layout_constraintStart_toEndOf="@id/tvPlayerName"
            app:layout_constraintTop_toTopOf="@id/tvPlayerName"
            app:layout_constraintBottom_toBottomOf="@id/tvPlayerName"/>

        <TextView
            android:id="@+id/tvLevel"
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:text="Lvl 8"
            android:textColor="?attr/colorTertiary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center_horizontal"/>

        <TextView
            android:id="@+id/tvScore"
            android:layout_width="80dp"
            android:layout_height="wrap_content"
            android:text="1250"
            android:textColor="?attr/colorTertiary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="end"/>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>