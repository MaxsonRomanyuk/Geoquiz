<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorBackgroundFloating"
    tools:context=".UI.PvP.DraftModeActivity">

    <LinearLayout
        android:id="@+id/layoutTopBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/ivBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_back"
            android:padding="6dp"
            android:clickable="true"
            android:focusable="true"
            app:tint="?attr/colorTertiaryFixed" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/draft_mode"
            android:textColor="?attr/colorTertiary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"/>
    </LinearLayout>

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/layoutTopBar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:fillViewport="true"
        android:padding="16dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:id="@+id/layoutVS"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp"
                app:layout_constraintTop_toTopOf="parent">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="70dp"
                        android:layout_height="70dp"
                        app:cardCornerRadius="35dp"
                        app:cardElevation="4dp"
                        app:strokeWidth="2dp"
                        app:strokeColor="?attr/colorPrimary"
                        app:cardBackgroundColor="?attr/colorSurface">

                        <ImageView
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_profile_placeholder"
                            app:tint="?attr/colorPrimary" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/tvPlayer1Name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PlayerABC"
                        android:textColor="?attr/colorTertiary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp"/>

                    <TextView
                        android:id="@+id/tvPlayer1Score"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1,100"
                        android:textColor="?attr/colorPrimary"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginTop="2dp"/>
                    <TextView
                        android:id="@+id/tvPlayer1Level"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Level 8"
                        android:textColor="?attr/colorPrimary"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginStart="4dp"/>
                </LinearLayout>

                <!-- VS логотип -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="VS"
                    android:textColor="?attr/colorAccent"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:layout_marginHorizontal="16dp"/>

                <!-- Игрок 2 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="70dp"
                        android:layout_height="70dp"
                        app:cardCornerRadius="35dp"
                        app:cardElevation="4dp"
                        app:strokeWidth="2dp"
                        app:strokeColor="?attr/colorSecondary"
                        app:cardBackgroundColor="?attr/colorSurface">

                        <ImageView
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_profile_placeholder"
                            app:tint="?attr/colorSecondary" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/tvPlayer2Name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PlayerXYZ"
                        android:textColor="?attr/colorTertiary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp"/>

                    <TextView
                        android:id="@+id/tvPlayer2Score"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1,000"
                        android:textColor="?attr/colorSecondary"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginTop="2dp"/>
                    <TextView
                        android:id="@+id/tvPlayer2Level"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Level 8"
                        android:textColor="?attr/colorSecondary"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginStart="4dp"/>
                </LinearLayout>
            </LinearLayout>



            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardTurnStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorTertiaryFixed"
                app:layout_constraintTop_toBottomOf="@id/layoutVS">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/card_background_game"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:id="@+id/tvTurnStatus"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/your_turn_ban"
                            android:textColor="?attr/colorTertiary"
                            android:textSize="16sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/tvTimer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="10s"
                            android:textColor="?attr/colorPrimary"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginEnd="12dp"/>

                        <ProgressBar
                            android:id="@+id/progressTurn"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:indeterminateTint="?attr/colorSecondary"
                            android:visibility="gone"/>
                    </LinearLayout>

                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/progressTimer"
                        android:layout_width="match_parent"
                        android:layout_height="4dp"
                        android:progress="0"
                        android:max="100"
                        app:indicatorColor="?attr/colorPrimary"
                        app:trackColor="?attr/colorSurfaceVariant"
                        android:visibility="gone"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvBanTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ban_category"
                android:textColor="?attr/colorTertiary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp"
                app:layout_constraintTop_toBottomOf="@id/cardTurnStatus"
                app:layout_constraintStart_toStartOf="parent"/>

            <androidx.gridlayout.widget.GridLayout
                android:id="@+id/gridGameModes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:columnCount="2"
                app:rowCount="2"
                app:useDefaultMargins="true"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/tvBanTitle">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardCapitals"
                    android:layout_width="0dp"
                    android:layout_height="125dp"
                    android:layout_marginEnd="8dp"
                    android:layout_marginBottom="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="?attr/colorTertiaryFixed"
                    app:layout_columnWeight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackground">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center">

                        <ImageView
                            android:id="@+id/ivCapital"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/capital"
                            android:scaleType="centerCrop"
                            android:contentDescription="@string/country_capitals" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                android:gravity="bottom|center_horizontal"
                                android:padding="8dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/country_capitals"
                                    android:textColor="?attr/colorOnContainer"
                                    android:textSize="14sp"
                                    android:textStyle="bold"
                                    android:layout_marginTop="8dp"
                                    tools:ignore="PrivateResource" />
                            </LinearLayout>
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardFlags"
                    android:layout_width="0dp"
                    android:layout_height="125dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginBottom="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="?attr/colorSurface"
                    app:strokeWidth="1dp"
                    app:strokeColor="?attr/colorTertiaryFixed"
                    app:layout_columnWeight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackground">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center">

                        <ImageView
                            android:id="@+id/ivFlag"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/flag"
                            android:scaleType="centerCrop"
                            android:contentDescription="@string/country_flags" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="bottom|center_horizontal"
                            android:padding="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/country_flags"
                                android:textColor="?attr/colorOnContainer"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:layout_marginTop="8dp"
                                tools:ignore="PrivateResource" />
                        </LinearLayout>
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardOutlines"
                    android:layout_width="0dp"
                    android:layout_height="125dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginBottom="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="?attr/colorSurface"
                    app:strokeWidth="1dp"
                    app:strokeColor="?attr/colorTertiaryFixed"
                    app:layout_columnWeight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackground">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center">

                        <ImageView
                            android:id="@+id/ivOutline"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/outline"
                            android:scaleType="centerCrop"
                            android:contentDescription="@string/country_outlines" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="bottom|center_horizontal"
                            android:padding="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/country_outlines"
                                android:textColor="?attr/colorOnContainer"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:layout_marginTop="8dp"
                                tools:ignore="PrivateResource" />
                        </LinearLayout>
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardLanguages"
                    android:layout_width="0dp"
                    android:layout_height="125dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginBottom="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="?attr/colorSurface"
                    app:strokeWidth="1dp"
                    app:strokeColor="?attr/colorTertiaryFixed"
                    app:layout_columnWeight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackground">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center">

                        <ImageView
                            android:id="@+id/ivLanguage"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/language"
                            android:scaleType="centerCrop"
                            android:contentDescription="@string/country_languages" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="bottom|center_horizontal"
                            android:padding="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/country_languages"
                                android:textColor="?attr/colorOnContainer"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:layout_marginTop="8dp"
                                tools:ignore="PrivateResource" />
                        </LinearLayout>
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>
            </androidx.gridlayout.widget.GridLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="24dp"
                app:layout_constraintTop_toBottomOf="@id/gridGameModes"/>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>