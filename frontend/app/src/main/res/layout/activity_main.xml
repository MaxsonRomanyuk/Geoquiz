<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background_gradient"
    tools:context=".presentation.ui.Home.MainActivity">

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/bottomNavigationView"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:id="@+id/topBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="20dp"
                android:paddingTop="16dp"
                android:paddingBottom="12dp"
                app:layout_constraintTop_toTopOf="parent"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvUsername"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Traveler42"
                    android:textColor="?attr/colorTertiary"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    app:cardBackgroundColor="@android:color/transparent"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:layout_marginEnd="12dp"
                    app:cornerRadius="20dp">

                    <TextView
                        android:id="@+id/tvDailyStreak"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="🔥 5"
                        android:textColor="?attr/colorAccent"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/ivProfile"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_profile_placeholder"
                    android:background="@drawable/circle_white_border"
                    android:padding="2dp"
                    app:tint="?attr/colorPrimary" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardLevel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorTertiaryFixed"
                app:layout_constraintTop_toBottomOf="@id/topBar">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/card_background_game"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvLevel"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/level_prefix"
                            android:textColor="?attr/colorTertiary"
                            android:textSize="24sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvXP"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1200/2000 XP"
                            android:textColor="?attr/colorTertiaryFixed"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/progressXP"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:layout_marginTop="8dp"
                        android:progress="30"
                        android:progressBackgroundTint="?attr/colorTertiaryFixed"
                        android:progressTint="?attr/colorPrimary" />

                    <TextView
                        android:id="@+id/tvTotalScore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:fontFamily="sans-serif-black"
                        android:text="3,250"
                        android:textColor="?attr/colorTertiary"
                        android:textSize="32sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/total_points"
                        android:textColor="?attr/colorTertiaryFixed"
                        android:textSize="12sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvGameModesTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginStart="25dp"
                android:text="@string/game_type"
                android:textColor="?attr/colorTertiary"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintTop_toBottomOf="@id/cardLevel"
                app:layout_constraintStart_toStartOf="parent"
                tools:ignore="MissingConstraints"/>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardSolo"
                android:layout_width="0dp"
                android:layout_height="105dp"
                android:layout_marginStart="15dp"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="6dp"
                app:cardBackgroundColor="?attr/colorPrimary"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorTertiaryFixed"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:layout_constraintDimensionRatio="w,1:1"
                app:layout_constraintEnd_toStartOf="@+id/cardDuel"
                app:layout_constraintHorizontal_chainStyle="spread"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvGameModesTitle">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageView
                        android:id="@+id/ivSoloMode"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/solo"
                        android:scaleType="centerCrop"
                        android:contentDescription="@string/solo" />


                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="bottom|center_horizontal"
                        android:padding="2dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/solo"
                            android:textColor="?attr/colorOnContainer"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:shadowColor="#80000000"
                            android:shadowDx="2"
                            android:shadowDy="2"
                            android:shadowRadius="4"
                            tools:ignore="PrivateResource" />
                    </LinearLayout>
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDuel"
                android:layout_width="0dp"
                android:layout_height="105dp"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                app:cardBackgroundColor="?attr/colorSecondary"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorTertiaryFixed"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:layout_constraintDimensionRatio="w,1:1"
                app:layout_constraintEnd_toStartOf="@+id/cardKing"
                app:layout_constraintStart_toEndOf="@+id/cardSolo"
                app:layout_constraintTop_toTopOf="@+id/cardSolo">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageView
                        android:id="@+id/ivDuelMode"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/pvp"
                        android:scaleType="centerCrop"
                        android:contentDescription="@string/duel" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="bottom|center_horizontal"
                        android:orientation="vertical"
                        android:padding="2dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:shadowColor="#80000000"
                            android:shadowDx="2"
                            android:shadowDy="2"
                            android:shadowRadius="4"
                            android:text="@string/duel"
                            android:textColor="?attr/colorOnContainer"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            tools:ignore="PrivateResource" />
                    </LinearLayout>

                    <View
                        android:id="@+id/vLockedOverlayPvP"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="#66000000"
                        android:visibility="gone"/>

                    <LinearLayout
                        android:id="@+id/layoutLockedBadgePvP"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="6dp"
                        android:background="@drawable/bg_locked_glass"
                        android:elevation="6dp"
                        android:visibility="gone">

                        <TextView
                            android:text="🔒"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="14sp"
                            android:layout_marginEnd="6dp"/>

                        <TextView
                            android:text="@string/unlock"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@android:color/white"/>
                    </LinearLayout>
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardKing"
                android:layout_width="0dp"
                android:layout_height="105dp"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="15dp"
                app:cardBackgroundColor="?attr/colorAccent"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorTertiaryFixed"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:layout_constraintDimensionRatio="w,1:1"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/cardDuel"
                app:layout_constraintTop_toTopOf="@+id/cardSolo">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageView
                        android:id="@+id/ivKingMode"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/king"
                        android:scaleType="centerCrop"
                        android:contentDescription="@string/king_of_the_hill" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="bottom|center_horizontal"
                        android:padding="2dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/king_of_the_hill"
                            android:textColor="?attr/colorOnContainer"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:shadowColor="#80000000"
                            android:shadowDx="2"
                            android:shadowDy="2"
                            android:shadowRadius="4"
                            tools:ignore="PrivateResource" />
                    </LinearLayout>

                    <View
                        android:id="@+id/vLockedOverlayKing"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="#66000000"
                        android:visibility="gone"/>

                    <LinearLayout
                        android:id="@+id/layoutLockedBadgeKing"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="6dp"
                        android:background="@drawable/bg_locked_glass"
                        android:elevation="6dp"
                        android:visibility="gone">

                        <TextView
                            android:text="🔒"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="14sp"
                            android:layout_marginEnd="6dp"/>

                        <TextView
                            android:text="@string/unlock"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@android:color/white"/>
                    </LinearLayout>
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvStatsTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginStart="25dp"
                android:text="@string/your_stats"
                android:textColor="?attr/colorTertiary"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintTop_toBottomOf="@id/cardSolo"
                tools:ignore="MissingConstraints"
                app:layout_constraintStart_toStartOf="parent"/>

            <androidx.gridlayout.widget.GridLayout
                android:id="@+id/gridStats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="12dp"
                app:columnCount="2"
                app:rowCount="2"
                app:layout_constraintTop_toBottomOf="@id/tvStatsTitle"
                tools:ignore="MissingClass">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_marginEnd="8dp"
                    android:layout_marginBottom="8dp"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:strokeWidth="1dp"
                    app:strokeColor="?attr/colorTertiaryFixed"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:layout_columnWeight="1"
                    app:layout_rowWeight="1">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/card_background_game"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/tvGamesPlayed"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="145"
                            android:textColor="?attr/colorPrimary"
                            android:textSize="24sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/games_played"
                            android:textColor="?attr/colorTertiaryFixed"
                            android:textSize="12sp"
                            android:gravity="center"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginBottom="8dp"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:strokeWidth="1dp"
                    app:strokeColor="?attr/colorTertiaryFixed"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:layout_columnWeight="1"
                    app:layout_rowWeight="1">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/card_background_game"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/tvWins"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="82"
                            android:textColor="?attr/colorSecondary"
                            android:textSize="24sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/wins"
                            android:textColor="?attr/colorTertiaryFixed"
                            android:textSize="12sp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_marginEnd="8dp"
                    android:layout_marginTop="8dp"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:strokeWidth="1dp"
                    app:strokeColor="?attr/colorTertiaryFixed"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:layout_columnWeight="1"
                    app:layout_rowWeight="1">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/card_background_game"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/tvAccuracy"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="78%"
                            android:textColor="?attr/colorSecondary"
                            android:textSize="24sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/accuracy"
                            android:textColor="?attr/colorTertiaryFixed"
                            android:textSize="12sp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="8dp"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:strokeWidth="1dp"
                    app:strokeColor="?attr/colorTertiaryFixed"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:layout_columnWeight="1"
                    app:layout_rowWeight="1">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/card_background_game"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/tvBestContinent"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/europe"
                            android:textColor="?attr/colorPrimary"
                            android:textSize="20sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/best_continent"
                            android:textColor="?attr/colorTertiaryFixed"
                            android:textSize="12sp"
                            android:gravity="center"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </androidx.gridlayout.widget.GridLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="24dp"
                app:layout_constraintTop_toBottomOf="@id/gridStats"/>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigationView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_bottom_nav"
        app:itemIconTint="@color/bottom_nav_icon"
        app:itemTextColor="@color/bottom_nav_text"
        app:itemRippleColor="?attr/colorPrimary"
        app:itemActiveIndicatorStyle="@style/NavIndicator"
        app:menu="@menu/bottom_nav_menu"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:labelVisibilityMode="labeled"
        app:elevation="12dp"/>
</androidx.constraintlayout.widget.ConstraintLayout>