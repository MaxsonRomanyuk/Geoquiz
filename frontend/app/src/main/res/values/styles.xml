<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="CircleShape">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="Widget.GeoQuiz.ToggleButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="backgroundTint">?attr/colorPrimary</item>
        <item name="android:textColor">?attr/colorTertiaryFixed</item>
        <item name="strokeColor">?attr/colorTertiaryFixed</item>
    </style>

    <style name="QuizOptionButton" parent="Widget.AppCompat.Button">
        <item name="android:layout_height">65dp</item>
        <item name="android:layout_margin">8dp</item>
        <item name="android:background">@drawable/option_button_selector</item>
        <item name="android:textColor">#1A365D</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <style name="EndGameButton" parent="Widget.AppCompat.Button">
        <item name="android:layout_height">60dp</item>
        <item name="android:background">#FF6B6B</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:stateListAnimator">@null</item>
    </style>
</resources>