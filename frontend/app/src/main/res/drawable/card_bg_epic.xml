<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <solid android:color="@color/card_bg_dark"/>
            <corners android:radius="16dp"/>
        </shape>
    </item>
    <item>
        <shape>
            <gradient
                android:startColor="@color/epic_rarity_light"
                android:endColor="@color/epic_rarity_dark"
                android:angle="135"
                android:alpha="0.25"/>
            <corners android:radius="16dp"/>
        </shape>
    </item>
    <item>
        <shape>
            <stroke
                android:width="2dp"
                android:color="@color/epic_rarity"
                android:dashWidth="8dp"
                android:dashGap="4dp"/>
            <corners android:radius="16dp"/>
        </shape>
    </item>
</layer-list>