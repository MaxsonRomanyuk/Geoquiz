<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <solid android:color="@color/card_bg_dark"/>
            <corners android:radius="16dp"/>
        </shape>
    </item>
    <item>
        <shape>
            <gradient
                android:startColor="@color/legendary_rarity_light"
                android:endColor="@color/legendary_rarity_dark"
                android:angle="135"
                android:alpha="0.3"/>
            <corners android:radius="16dp"/>
        </shape>
    </item>
    <item>
        <shape>
            <stroke
                android:width="3dp"
                android:color="@color/legendary_rarity"/>
            <corners android:radius="16dp"/>
        </shape>
    </item>
    <item>
        <shape>
            <stroke
                android:width="1dp"
                android:color="@android:color/white"
                android:alpha="0.5"/>
            <corners android:radius="16dp"/>
        </shape>
    </item>
</layer-list>