        <activity
            android:name=".presentation.ui.profile.SettingsActivity"
            android:exported="false"/>
        <activity
            android:name=".presentation.ui.soloGame.GameModesActivity"
            android:exported="false"/>
        <activity
            android:name=".presentation.ui.soloGame.GameTypesActivity"
            android:exported="false"/>
        <activity
            android:name=".presentation.ui.soloGame.SoloGameActivity"
            android:exported="false"/>
        <activity
            android:name=".presentation.ui.soloGame.GameResultActivity"
