<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <uses-permission android:name="android.permission.INTERNET"/>
    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:networkSecurityConfig="@xml/network_security_config"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.GeoQuiz_frontend">
        <activity
            android:name=".Presentation.ui.Auth.LoginActivity"
            android:exported="true"
            tools:ignore="Instantiatable">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".Presentation.ui.Home.MainActivity"
            android:exported="false"/>
        <activity
            android:name=".Presentation.ui.Profile.ProfileActivity"
            android:exported="false"/>
        <activity
            android:name=".Presentation.ui.Profile.SettingsActivity"
            android:exported="false"/>
        <activity
            android:name=".Presentation.ui.Game.GameModesActivity"
            android:exported="false"/>
        <activity
            android:name=".Presentation.ui.Game.GameTypesActivity"
            android:exported="false"/>
        <activity
            android:name=".Presentation.ui.Game.SoloGameActivity"
            android:exported="false"/>
        <activity
            android:name=".Presentation.ui.Game.GameResultActivity"
            android:exported="false"/>
        <activity
            android:name=".Presentation.ui.PvP.MatchmakingActivity"
            android:exported="false"/>
        <activity
            android:name=".Presentation.ui.PvP.DraftModeActivity"
            android:exported="false"/>
        <activity
            android:name=".Presentation.ui.PvP.PvPGameActivity"
            android:exported="false"/>
        <activity
            android:name=".Presentation.ui.PvP.PvPResultActivity"
            android:exported="false"/>
        <activity
            android:name=".Presentation.ui.King.KingLobbyActivity"
            android:exported="false"/>
        <activity
            android:name=".Presentation.ui.King.KingGameActivity"
            android:exported="false"/>
    </application>

</manifest>